PORT=5000
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=your_password
DB_NAME=ooj_events
DB_PORT=3306

# Email (Gmail SMTP — use an App Password, not your regular Gmail password)
# https://support.google.com/accounts/answer/185833
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_16_char_app_password
EMAIL_FROM="OOJ Foundation" <your_email@gmail.com>

# Admin (use strong values in production)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change_this_password_before_production
JWT_SECRET=change_this_to_a_random_secret_at_least_32_chars_long

# Frontend URL (for CORS and email links)
FRONTEND_URL=http://localhost:5173
