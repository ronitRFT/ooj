# Use relative /api in dev — Vite proxies to backend (avoids mixed-content on HTTPS)
VITE_API_URL=/api
VITE_PROXY_TARGET=http://127.0.0.1:5000

# For phone testing on LAN, set your Mac IP:
# VITE_PROXY_TARGET=http://192.168.1.129:5000
#
# Production build — set full HTTPS API URL:
# VITE_API_URL=https://api.yourdomain.com/api
